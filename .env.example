# ═══════════════════════════════════════════════════════════════
# ULTRON v2.1 - Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your API keys
# No API keys are required - Ultron works with local models only
# ═══════════════════════════════════════════════════════════════

# ── Local Models (No API Key Required) ──────────────────────

# Ollama (default local model)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# AirLLM (Run Llama 3.1 70B/405B on consumer GPUs)
# 70B model → ~4GB VRAM, ~35GB disk
# 405B model → ~8GB VRAM, ~230GB disk
# Requires: pip install airllm accelerate
AIRLLM_MODEL=meta-llama/Llama-3.1-70B-Instruct
AIRLLM_COMPRESSION=4bit
AIRLLM_PREFETCHING=true
AIRLLM_MAX_LENGTH=4096
# HuggingFace token for gated models (Llama 3 requires access request)
# Get token from: https://huggingface.co/settings/tokens
# Then request access at: https://huggingface.co/meta-llama/Llama-3.1-70B-Instruct
HUGGING_FACE_HUB_TOKEN=
HF_TOKEN=

# ── Cloud AI Providers (Optional Fallbacks) ─────────────────

# Groq (Ultra-fast inference - Free tier available)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini (Free tier - 1M context)
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenRouter (200+ models - Free tier available)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Cloudflare Workers AI (Free - 10K requests/day)
# Get key: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=

# Together AI ($25 free credits)
# Get key: https://api.together.xyz/
TOGETHER_API_KEY=

# Hugging Face Inference API (Free tier)
# Get key: https://huggingface.co/settings/tokens
HF_API_KEY=

# MiniMax M2.7 (Self-evolving model)
# Available via OpenRouter or official API
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_DEFAULT_MODEL=minimax-m2.7

# DeepSeek (Cheap + powerful code generation)
# Get key: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Anthropic Claude (Best understanding)
# Get key: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Mistral (GDPR compliant)
# Get key: https://console.mistral.ai/
MISTRAL_API_KEY=

# Cohere (RAG reranking)
# Get key: https://dashboard.cohere.com/
COHERE_API_KEY=

# Fireworks (Ultra-fast inference)
# Get key: https://fireworks.ai/
FIREWORKS_API_KEY=

# OpenAI (Ultimate fallback)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Email Agent (Optional) ──────────────────────────────────
ULTRON_EMAIL_USER=
ULTRON_EMAIL_PASS=

# ── API Protection (Optional) ───────────────────────────────
ULTRON_API_KEY=

# ── Allowed Origins (CORS) ──────────────────────────────────
ULTRON_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ── Web Search & Research ───────────────────────────────────────────
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx # Tavily.com'dan alinir
DUCKDUCKGO_REGION=tr-tr

# ── OpenClaw / ClawHub tarzı skill & ajan dizinleri (isteğe bağlı) ──
# [awesome-openclaw-skills](https://github.com/VoltAgent/awesome-openclaw-skills) veya
# [ClawHub](https://clawhub.ai/skills?sort=downloads) kaynaklı SKILL.md klasörlerini klonlayıp ekleyin.
# Windows: birden fazla yol için noktalı virgül (;), POSIX: iki nokta üst üste (:)
ULTRON_SKILLS_PATH=
ULTRON_AGENTS_PATH=
# JSON: [{"name":"my_skill","path":"C:/path/to/skill_dir","description":"..."}]
ULTRON_SKILLS_MANIFEST=

# MCP stdio sunucuları (varsayılan: proje/config/mcp.yaml)
ULTRON_MCP_CONFIG=
