# Jarvis Environment Variables
# Completely local — no API key required

# Email credentials (for morning summary)
JARVIS_EMAIL_USER=your_email@gmail.com
JARVIS_EMAIL_PASS=your_app_password_here

# Ollama server address (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# ═══════════════════════════════════════════════════════════
# Multi-Provider Support (Optional — all free)
# ═══════════════════════════════════════════════════════════

# OpenRouter (free + paid models — single API key)
# openrouter.ai → Settings → API Keys
OPENROUTER_API_KEY=your_openrouter_key_here

# Groq (super fast, free — 300-500 tok/s)
# console.groq.com → API Keys
GROQ_API_KEY=your_groq_key_here

# Google Gemini (free, 1M context, 60 req/min)
# aistudio.google.com → API Key
GEMINI_API_KEY=your_gemini_key_here

# Cloudflare Workers AI (free, 10K/day)
# dash.cloudflare.com → API Tokens + Account ID
CLOUDFLARE_API_KEY=your_cloudflare_key_here
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here

# Together AI ($25 free credit)
# api.together.xyz → Settings → API Keys
TOGETHER_API_KEY=your_together_key_here

# Hugging Face Inference API (free)
# huggingface.co → Settings → Access Tokens
HF_API_KEY=your_hf_token_here

# OpenAI (paid — last resort fallback)
OPENAI_API_KEY=your_openai_key_here
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# ═══════════════════════════════════════════════════════════
# n8n Integration (Optional)
# ═══════════════════════════════════════════════════════════
N8N_WEBHOOK_BASE_URL=http://localhost:5678
N8N_ENABLED=true

# ═══════════════════════════════════════════════════════════
# Future Providers (Add keys when ready)
# ═══════════════════════════════════════════════════════════
ANTHROPIC_API_KEY=your_anthropic_key_here
MISTRAL_API_KEY=your_mistral_key_here

COHERE_API_KEY=your_cohere_key_here

DEEPSEEK_API_KEY=your_deepseek_key_here

PERPLEXITY_API_KEY=your_perplexity_key_here

FIREWORKS_API_KEY=your_fireworks_key_here

ELEVENLABS_API_KEY=your_elevenlabs_key_here

FAL_API_KEY=your_fal_key_here
